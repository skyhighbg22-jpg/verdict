# =============================================================================
# VERDICT Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual API keys
# =============================================================================
# API Provider Keys
# =============================================================================
# OpenAI API Key (for GPT models)
# Get your key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Google AI API Key (for Gemini models)
# Get your key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (for fast inference and testing mode)
# Get your key from: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# Bytez API Key (unified provider)
# Get your key from: https://bytez.com
VITE_BYTEZ_API_KEY=your_bytez_api_key_here

# OpenRouter API Key (multi-provider fallback)
# Get your key from: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# NVIDIA API Key (for step flash and nemotron 3 super models)
# Get your key from: https://api.nvidia.com/
VITE_NVIDIA_API_KEY=your_nvidia_api_key_here

# =============================================================================
# Configuration Flags
# =============================================================================
# Testing Mode: When true, ALL requests route through OpenRouter with free models (ignores other providers)
# Useful for development and testing without managing multiple API keys
# Uses free models including minimax/minimax-m2.5:free and deepseek-ai/deepseek-v3.2
VITE_TESTING_MODE=false

# Enable Fallback Chain: If true, providers will fallback on errors
# Fallback order: Primary Provider → Bytez → OpenRouter
VITE_ENABLE_FALLBACK=true

# Maximum Retries: Number of retry attempts per provider
VITE_MAX_RETRIES=3

# Request Timeout: Timeout in milliseconds for API requests
VITE_REQUEST_TIMEOUT=30000

# =============================================================================
# Logging Configuration
# =============================================================================
# Log Level: debug | info | warn | error
VITE_LOG_LEVEL=info

# Log Provider Usage: Log which provider handled each request
VITE_LOG_PROVIDER_USAGE=true

# =============================================================================
# Model Mappings (Internal IDs to Provider Models)
# =============================================================================
# When TESTING_MODE=true, all models use Groq's smart models
# Otherwise, these mappings determine which actual models to use

# GPT-5.4 Pro mappings
VITE_GPT_5_4_PRO_OPENAI=gpt-4o
VITE_GPT_5_4_PRO_GROQ=llama-3.3-70b-versatile
VITE_GPT_5_4_PRO_NVIDIA=nemotron-3-super

# Claude Opus 4.6 mappings
VITE_CLAUDE_OPUS_4_6_OPENROUTER=anthropic/claude-3-opus
VITE_CLAUDE_OPUS_4_6_GROQ=llama-3.3-70b-versatile
VITE_CLAUDE_OPUS_4_6_NVIDIA=nemotron-3-super

# Gemini 3.1 Pro mappings
VITE_GEMINI_3_1_PRO_GOOGLE=gemini-1.5-pro
VITE_GEMINI_3_1_PRO_GROQ=llama-3.3-70b-versatile
VITE_GEMINI_3_1_PRO_NVIDIA=nemotron-3-super

# Grok 4.2 mappings
VITE_GROK_4_2_GROQ=mixtral-8x7b-32768
VITE_GROK_4_2_OPENROUTER=x-ai/grok-beta
VITE_GROK_4_2_NVIDIA=step-flash

# Step Flash mappings
VITE_STEP_FLASH_NVIDIA=step-flash
VITE_STEP_FLASH_OPENROUTER=step-ai/step-flash

# Nemotron 3 Super mappings
VITE_NEMOTRON_3_SUPER_NVIDIA=nemotron-3-super
VITE_NEMOTRON_3_SUPER_OPENROUTER=nvidia/nemotron-3-super

# =============================================================================
# Free Mode Model Mappings (Shows what free models are actually used)
# =============================================================================
# These show the actual free models that would be used in FREE MODE
# (when no enterprise credentials are configured and fallbacks are used)

# Free mode mappings for OpenRouter (what gets used when falling back to free models)
VITE_OPERATION_FREE_GPT_5_4_PRO=openrouter/hunter-alpha  # main model (more smarter)
VITE_OPERATION_FREE_GEMINI_3_1_PRO=openrouter/hunter-alpha  # main model (more smarter)
VITE_OPERATION_FREE_GROK_4_2=openrouter/hunter-alpha  # main model (more smarter)
VITE_OPERATION_FREE_CLAUDE_OPUS_4_6=openrouter/hunter-alpha  # main model (more smarter)
VITE_OPERATION_FREE_STEP_FLASH=minimax/minimax-m2.5:free  # second main model
VITE_OPERATION_FREE_NEMOTRON_3_SUPER=minimax/minimax-m2.5:free  # second main model

# Testing mode mappings (shows what gets used in testing mode)
# These correspond to what's actually used when VITE_TESTING_MODE=true
VITE_TESTING_GPT_5_4_PRO=deepseek-ai/deepseek-v3.2  # for reasoning/coding tasks
VITE_TESTING_GEMINI_3_1_PRO=openrouter/hunter-alpha  # main model (more smarter)
VITE_TESTING_GROK_4_2=openrouter/hunter-alpha  # main model (more smarter)
VITE_TESTING_CLAUDE_OPUS_4_6=deepseek-ai/deepseek-v3.2  # for reasoning/coding tasks
VITE_TESTING_STEP_FLASH=minimax/minimax-m2.5:free  # second main model
VITE_TESTING_NEMOTRON_3_SUPER=minimax/minimax-m2.5:free  # second main model
